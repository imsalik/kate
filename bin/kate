#!/usr/bin/env bash
# kate — a k9s-inspired Kubernetes TUI built on OpenTUI.
# Talks to the cluster directly via @kubernetes/client-node (no kubectl shell-out).
set -euo pipefail
APP_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../app" && pwd)"

# Make sure bun is reachable inside non-login tmux popup shells (the kate.tmux
# plugin launches us via `display-popup`, which doesn't source a login profile).
export PATH="$HOME/.bun/bin:$HOME/.local/bin:/usr/local/bin:$PATH"

if ! command -v bun >/dev/null 2>&1; then
  printf '\033[31mkate: `bun` not found in PATH\033[0m\n'
  printf 'install bun: https://bun.sh\n\n'
  read -n 1 -s -r -p "press any key to close..."
  exit 1
fi

# First-run install (TPM / a fresh clone won't have node_modules).
if [[ ! -d "$APP_DIR/node_modules" ]]; then
  printf '\033[33mkate: first run, installing dependencies...\033[0m\n'
  if ! (cd "$APP_DIR" && bun install); then
    printf '\033[31mkate: bun install failed\033[0m\n'
    read -n 1 -s -r -p "press any key to close..."
    exit 1
  fi
  printf '\n'
fi

# Bun's fetch ignores the per-cluster CA that client-node reads from kubeconfig,
# so verification fails against private CAs (e.g. GKE) out of the box. Rather
# than disable TLS verification globally, we do what client-go (k9s/kubectl)
# does: extract the current context's cluster CA and trust *that* — Bun's fetch
# does honor NODE_EXTRA_CA_CERTS. Verification stays ON.
#
# Escape hatch: KATE_INSECURE_TLS=1 restores the old blanket-disable behavior.
if [ "${KATE_INSECURE_TLS:-0}" = "1" ]; then
  export NODE_TLS_REJECT_UNAUTHORIZED=0
else
  # Reuse one file per user so repeated launches overwrite rather than pile up.
  CA_FILE="${TMPDIR:-/tmp}/kate-ca-$(id -u).pem"
  if bun run "$APP_DIR/src/tools/dump-ca.ts" >"$CA_FILE" 2>/dev/null && [ -s "$CA_FILE" ]; then
    export NODE_EXTRA_CA_CERTS="$CA_FILE"
  else
    rm -f "$CA_FILE"
    echo "kate: couldn't extract a cluster CA from kubeconfig — falling back to" >&2
    echo "      insecure TLS (verification off). Set KATE_INSECURE_TLS=1 to silence." >&2
    export NODE_TLS_REJECT_UNAUTHORIZED=0
  fi
fi

# Kill any prior kate instance first. `bun run` has no file-watch, so a lingering
# old process would keep running stale code — restarting must mean a clean start.
pkill -f "bun run $APP_DIR/src/main.tsx" 2>/dev/null || true

exec bun run "$APP_DIR/src/main.tsx" "$@"
